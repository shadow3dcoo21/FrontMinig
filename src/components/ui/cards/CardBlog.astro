---
// Import necessary components and utilities
import AvatarBlog from "@components/ui/avatars/AvatarBlog.astro";
import { formatDate } from "@utils/utils";

// Extraemos las props
const { blogEntry } = Astro.props;

// Definimos la interfaz para TypeScript
interface Props {
  blogEntry: {
    data: {
      title: string;
      pubDate: Date;
      description: string;
      content: string;
      image: {
        url: string;
        alternativeText?: string;
        formats?: any;
        originalImageData?: any;
      };
      paragraphs: {
        primary: Array<{id: number; Paragraph: string}>;
        secondary: Array<{id: number; Paragraph: string}>;
      };
    };
    id: string;
    slug: string;
  };
}

// Preparamos los datos para la página de detalles
const detailData = {
  title: blogEntry.data.title,
  description: blogEntry.data.description,
  pubDate: blogEntry.data.pubDate,
  imageUrl: `http://100.42.184.197:8082${blogEntry.data.image.url}`,
  paragraphs: blogEntry.data.paragraphs,
  content: blogEntry.data.content,
  imageFormats: blogEntry.data.image.formats,
  originalImage: blogEntry.data.image.originalImageData
};
---

<!-- Debug: Mostrar datos que se enviarán -->
<pre class="hidden">{
  JSON.stringify({
    detailData: detailData,
    fullEntry: blogEntry
  }, null, 2)
}</pre>

<!-- Contenedor principal de la tarjeta --> 
<a
  class="group relative block rounded-xl outline-hidden ring-zinc-500 transition duration-500 focus-visible:ring-3 dark:ring-zinc-200 dark:focus:outline-hidden"
  href={`/blog/${blogEntry.id}/?data=${encodeURIComponent(JSON.stringify(detailData))}`}
  data-astro-prefetch
>
  <!-- Contenedor de la imagen -->
  <div
    class="relative h-[350px] w-full shrink-0 overflow-hidden rounded-xl before:absolute before:inset-x-0 before:z-1 before:size-full before:bg-linear-to-t before:from-neutral-900/[.7]"
  >
    {blogEntry.data.image?.url ? (
      <img
        class="absolute start-0 top-0 size-full object-cover transition duration-500 group-hover:scale-110"
        src={`http://100.42.184.197:8082${blogEntry.data.image.url}`}
        alt={blogEntry.data.image.alternativeText || blogEntry.data.title}
        draggable="false"
        loading="eager"
        width="800"
        height="450"
      />
    ) : (
      <div class="absolute start-0 top-0 size-full bg-gray-200 flex items-center justify-center">
        <span class="text-gray-500">Imagen no disponible</span>
      </div>
    )}
  </div>
  
  <!-- Información de fecha -->
  <div class="absolute inset-x-0 top-0 z-10">
    <div class="flex h-full flex-col p-4 sm:p-6">
      <div class="flex items-center">
        <div class="ms-2.5 sm:ms-4">
          <p class="text-xs text-neutral-50/[.8]">
            {formatDate(blogEntry.data.pubDate)}
          </p>
        </div>
      </div>
    </div>
  </div>
  
  <!-- Título y descripción -->
  <div class="absolute inset-x-0 bottom-0 z-10">
    <div class="flex h-full flex-col p-4 sm:p-6">
      <h3
        class="text-balance text-lg font-bold text-neutral-50 group-hover:text-neutral-50/[.8] sm:text-3xl"
      >
        {blogEntry.data.title}
      </h3>
      <p class="mt-2 text-pretty text-neutral-50/[.8]">
        {blogEntry.data.description}
      </p>
    </div>
  </div>
</a>